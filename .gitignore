# Ignore PDFs by default
*.pdf

# But allow PDF figures in image folders
!**/img/**/*.pdf
!**/images/**/*.pdf
!**/fig/**/*.pdf
!**/figures/**/*.pdf

# Track the final PDF at the root
!/Manuscrit_de_these.pdf
